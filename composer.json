{
	"name": "obenweb/ai-provider-for-open-webui",
	"description": "OpenWebUI provider for the WordPress AI Client.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=7.4"
	},
	"autoload": {
		"psr-4": {
			"OBenWeb\\AiProviderForOpenWebUI\\": "includes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"OBenWeb\\AiProviderForOpenWebUI\\Tests\\": "tests/"
		}
	},
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^1.1",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"phpcsstandards/phpcsextra": "^1.2",
		"phpcsstandards/phpcsutils": "^1.1",
		"phpunit/phpunit": "^9.6",
		"squizlabs/php_codesniffer": "^3.10",
		"wp-coding-standards/wpcs": "^3.2"
	},
	"scripts": {
		"test": "phpunit --configuration phpunit.xml.dist",
		"build": "bash scripts/build-release.sh",
		"lint": "phpcs",
		"lint:fix": "phpcbf"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"sort-packages": true
	}
}
